            "code": "<div class=\"collection-slider\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Smoking-accessories-for-sale.jpg?v=1684209618\"  alt=\"Smoking Accessoires For Sale\" ></a>\n</div><div class=\"collection-des\">\n  <h1 class=\"collection-header\"> The Best Smoking Accessories</h1>\n  Check out Headshop.com'sensive collection of great smoking accessories!! We have all the best gear including <a href=\"https://www.headshop.com/collections/bong-bowls\">bong bowls</a>, <a href=\"https://www.headshop.com/collections/downstems\"> downstems</a>, <a href=\"/collections/grinders\">grinders</a>, branded <a href=\"/collections/stash-gear\">stash gear</a> and more. All our smoking accessories have been tested for quality.</div>\n</div>\n<div class=\"subcat-main\">\n<div class=\"subcat-inner\" align=\"center\">\n\t\n\t<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/bong-accessories\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Bong-Accessoires.png?v=1684251921\" alt=\"Bong Accessories\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/bong-accessories\" style=\"text-decoration: none;\">Bongs Accessories</a></div>\n</div>\n\t\n\t<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/dab-rig-accessories\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Dab-Accessoires.png?v=1684251922\" alt=\"Dab Accessories\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/dab-rig-accessories\" style=\"text-decoration: none;\">Dab Accessories</a></div>\n</div>\n\t\n\t<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/rolling-papers\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Rolling-Papers.png?v=1684251921\" alt=\"Rolling Papers\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/rolling-papers\" style=\"text-decoration: none;\">Rolling Papers</a></div>\n</div>\n\t\n\t<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/grinder-accessories\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Grinders-For-Sale.png?v=1684251922\" alt=\"Grinders\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/grinder-accessories\" style=\"text-decoration: none;\">Grinders</a></div>\n</div>\n\t\n<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/stash-gear\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Stash-Gear_3c99b3e6-a355-4453-9b89-89c868f81abf.png?v=1684251923\" alt=\"Stash Gear\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/stash-gear\" style=\"text-decoration: none;\">Stash Gear</a></div>\n</div>\n\t\n\t<div class=\"subcat\">\n<div class=\"subcat-image\"><a href=\"/collections/vape-accessories\"><img src=\"https://cdn.shopify.com/s/files/1/0585/8462/9443/files/Vape-Accessories_cf1647aa-dc1a-4d52-af26-e9e585d784cb.png?v=1684251922\" alt=\"Vape Accessories\"></a></div>\n<div class=\"subcat-des\"><a href=\"/collections/vape-accessories\" style=\"text-decoration: none;\">Vape Accessories</a></div>\n</div>\n</div>\n\n<div class=\"subcat-bottom\"></div>",
