          "type": "text",
          "settings": {
            "enlarge_text": false,
            "text": "<p>HERE ARE SOME OF THE MOST FREQUENTLY ASKED QUESTIONS WE RECEIVE AT HEADSHOP.COM</p>"
          }
        },
        "65d8f211-c3b5-4b1e-9726-987e5d58a0cc": {
          "type": "text",
          "settings": {
            "enlarge_text": true,
            "text": "<h5>Don’t see the answer to your question here?</h5>"
          }
        },
