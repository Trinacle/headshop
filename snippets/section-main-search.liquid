{%- comment -%}
  Renders a search section with an input form and search results.

  Accepts:
  - paginate_by {number} - Number of products to show per page
  - hydration {string} - Hydration strategy for the component

  Usage:
  {% render 'section-main-search' %}
{%- endcomment -%}

{%- liquid
  assign paginate_by = paginate_by | default: section.settings.paginate_by | default: 40

  # Separate products from articles/pages so they display in grouped sections
  capture product_cards
    paginate search.results by paginate_by
      for item in search.results
        if item.object_type == 'product'
          render 'product-grid-item', product: item
        endif
      endfor
      assign search_pagination = paginate
    endpaginate
  endcapture

  capture article_cards
    for item in search.results
      if item.object_type != 'product'
        render 'search-grid-item', item: item
      endif
    endfor
  endcapture
-%}

{%- capture search_content -%}
  <div class="new-grid product-grid collection-grid" data-view="{{ section.settings.grid_style }}" data-scroll-to>
    {{ product_cards }}
  </div>
  {%- if article_cards != blank -%}
    <div class="search-results-articles">
      <h2 class="section-header__title search-results-articles__heading">Related Blog Posts</h2>
      <div class="new-grid product-grid collection-grid search-results-articles__grid" data-view="{{ section.settings.grid_style }}">
        {{ article_cards }}
      </div>
    </div>
  {%- endif -%}
  {%- if search_pagination.pages > 1 -%}
    <div class="search-infinite-scroll-pagination" data-search-pagination>
      {%- render 'pagination', paginate: search_pagination -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<section-main-search class="page-width page-content">
  <header class="section-header">
    <h1 class="section-header__title">
      {% render 't_with_fallback', key: 'labels.search', fallback: 'Search' %}
    </h1>
    <p class="medium-up--hide" data-collection-count>
      {% assign info_search_result_count = 'info.search_result_count' | t: count: search.results_count %}
      {%- capture fallback_info_search_result_count -%}
        {{ search.results_count }} result{%- if ssearch.results_count != 1 -%}s{%- endif -%}
      {%- endcapture -%}
      {% render 't_with_fallback', t: info_search_result_count, fallback: fallback_info_search_result_count %}
    </p>
  </header>

  {%- render 'predictive-search', context: 'search-page' -%}

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <div class="section-header">
        <p>
          {% assign info_search_no_results_html = 'info.search_no_results_html'
            | t: terms: search.terms
            | replace: '*', ''
          %}
          {%- capture fallback_info_search_no_results_html -%}
            Search for "{{ search.terms | replace: '*', '' }}"
          {%- endcapture -%}
          {% render 't_with_fallback', t: info_search_no_results_html, fallback: fallback_info_search_no_results_html %}
        </p>
      </div>
    {%- else -%}
      <div class="main-search__content">
        {%- render 'item-grid', context: search, slot: search_content, paginate_by: paginate_by -%}
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- if search.performed and search.results_count > 0 and search_pagination.pages > 1 -%}
    <script>
      (function () {
        var productGrid = document.querySelector('.main-search__content .product-grid:not(.search-results-articles__grid)');
        var paginationWrap = document.querySelector('[data-search-pagination]');
        if (!productGrid || !paginationWrap) return;

        var nextLink = paginationWrap.querySelector('a[href*="page="]');
        if (!nextLink) return;

        var loading = false;
        var observer = new IntersectionObserver(function (entries) {
          if (entries[0].isIntersecting && !loading) {
            loadMore();
          }
        }, { rootMargin: '400px' });

        observer.observe(paginationWrap);

        function loadMore() {
          var link = paginationWrap.querySelector('a[href*="page="]');
          if (!link || loading) return;
          loading = true;

          fetch(link.href)
            .then(function (res) { return res.text(); })
            .then(function (html) {
              var parser = new DOMParser();
              var doc = parser.parseFromString(html, 'text/html');
              var newProducts = doc.querySelectorAll('.main-search__content .product-grid:not(.search-results-articles__grid) > *');
              var newPagination = doc.querySelector('[data-search-pagination]');

              newProducts.forEach(function (el) { productGrid.appendChild(el); });

              if (newPagination && newPagination.querySelector('a[href*="page="]')) {
                paginationWrap.innerHTML = newPagination.innerHTML;
                loading = false;
              } else {
                paginationWrap.style.display = 'none';
                observer.disconnect();
              }
            })
            .catch(function () { loading = false; });
        }
      })();
    </script>
  {%- endif -%}
</section-main-search>
