{% comment %}
  Preloads javascript modules from the importmap.

  Optimization: only preload modules that the page actually references in
  its <script type="module"> blocks, rather than every entry in the import
  map. This avoids downloading ~40 unused modules per page.
{% endcomment %}

<script type="module">
  try {
    const importMap = document.querySelector('script[type="importmap"]')
    const importMapJson = JSON.parse(importMap.textContent)
    const importMapEntries = importMapJson.imports

    // Collect module specifiers actually used on this page
    const usedSpecifiers = new Set()
    document.querySelectorAll('script[type="module"]').forEach(function (script) {
      const matches = script.textContent.matchAll(/import\s+(?:[^'"]+\s+from\s+)?['"]([^'"]+)['"]/g)
      for (const match of matches) {
        usedSpecifiers.add(match[1])
      }
    })

    // Preload only the used modules that exist in the import map
    for (const specifier of usedSpecifiers) {
      if (importMapEntries[specifier]) {
        const link = document.createElement('link')
        link.rel = 'modulepreload'
        link.href = importMapEntries[specifier]
        document.head.appendChild(link)
      }
    }
  } catch (e) {
    console.error(e)
  }
</script>
